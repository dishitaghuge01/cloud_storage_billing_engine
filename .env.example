# Environment variables template for Multi-Tenant Cloud Storage Billing Engine
# Copy this file to .env and fill in your actual values. NEVER commit .env to git.

# ============================================
# BACKEND - MinIO Configuration
# ============================================
MINIO_ENDPOINT=http://localhost:9000
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=password123
STORAGE_BUCKET_NAME=cloud-storage

# ============================================
# BACKEND - Supabase Configuration
# ============================================
SUPABASE_PROJECT_ID=your-project-id
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# ============================================
# BACKEND - Upstash Redis
# ============================================
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# ============================================
# BACKEND - Razorpay Payment
# ============================================
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_key_secret
RAZORPAY_TEST_SUB_ID=sub_your_subscription_id

# ============================================
# FRONTEND - Supabase Client (Public Keys)
# ============================================
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
